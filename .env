# Mode de données de l'application
# 'local' : Utilise le localStorage (comportement par défaut, 100% offline)
# 'remote' : Utilise l'API distante (architecture Backend-Ready, non activée par défaut)
VITE_DATA_MODE=local

# URL de l'API (utilisée par apiClient.ts si VITE_DATA_MODE=remote)
# Non utilisé par défaut — l'application est 100% offline-first.
VITE_API_URL=http://localhost:3000/api

# Clé d'accès pour Web3Forms (formulaire de signalement de bug / suggestion)
# Créez une clé gratuite sur https://web3forms.com avec l'adresse geoffroy.streit@gmail.com
# ⚠️ Dans Coolify : définir comme "Build Variable" pour qu'elle soit injectée au moment du npm run build.
VITE_WEB3FORMS_ACCESS_KEY=b6ee5a0a-39e2-4a15-ba87-e7fb23353ec7
